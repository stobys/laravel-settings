{
    "name": "stobys/laravel-settings",
    "description": "Simple key/value settings manager for Laravel with per-user support and file cache.",
    "homepage": "https://github.com/stobys/laravel-settings",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "settings"
    ],
    "authors": [
        {
            "name": "Sławomir Tobys",
            "email": "s.tobys@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/cache": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "stobys\\Settings\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "stobys\\Settings\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "stobys\\Settings\\SettingsServiceProvider"
            ],
            "aliases": {
                "Settings": "stobys\\Settings\\Facades\\Settings"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
